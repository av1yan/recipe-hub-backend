// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String     @id @default(cuid())
  email         String     @unique
  name          String
  username      String?    @unique
  // Null for accounts created through Google/Apple, which have no password.
  passwordHash  String?
  googleId      String?    @unique
  appleId       String?    @unique
  avatar        String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  recipes       Recipe[]
  mealPlans     MealPlan[]
  groceryLists  GroceryList[]
  cookbooks     Cookbook[]
  savedRecipes  SavedRecipe[]
  ratings       RecipeRating[]
  resetTokens   PasswordResetToken[]
  householdMemberships HouseholdMember[]
  sharedGroceryAdds    SharedGroceryItem[] @relation("SharedGroceryAddedBy")
}

model PasswordResetToken {
  id         String    @id @default(cuid())
  // The SHA-256 of the token, never the token itself: anyone reading this table
  // must not be able to seize an account with what they find.
  tokenHash  String    @unique
  userId     String
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime  @default(now())

  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Recipe {
  id            String     @id @default(cuid())
  userId        String
  name          String
  description   String?
  cuisine       String
  mealType      String
  difficulty    String
  prepTime      Int
  cookTime      Int
  servings      Int
  calories      Int?
  imageUrl      String?
  sourceUrl     String?
  userNotes     String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  ingredients   Ingredient[]
  instructions  Instruction[]
  nutrition     Nutrition?
  tags          RecipeTag[]
  savedBy       SavedRecipe[]
  ratings       RecipeRating[]
  mealPlanRecipes MealPlanRecipe[]
  cookbookRecipes CookbookRecipe[]
  groceryItems  GroceryItem[]
}

model Ingredient {
  id            String     @id @default(cuid())
  recipeId      String
  name          String
  quantity      Float
  unit          String
  createdAt     DateTime   @default(now())

  recipe        Recipe     @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  groceryItems  GroceryItem[]
}

model Instruction {
  id            String     @id @default(cuid())
  recipeId      String
  stepNumber    Int
  text          String
  duration      Int?
  createdAt     DateTime   @default(now())

  recipe        Recipe     @relation(fields: [recipeId], references: [id], onDelete: Cascade)
}

model Nutrition {
  id            String     @id @default(cuid())
  recipeId      String     @unique
  calories      Int
  protein       Int
  carbs         Int
  fat           Int
  fiber         Int?
  allergens     String?

  recipe        Recipe     @relation(fields: [recipeId], references: [id], onDelete: Cascade)
}

model RecipeTag {
  id            String     @id @default(cuid())
  recipeId      String
  tag           String

  recipe        Recipe     @relation(fields: [recipeId], references: [id], onDelete: Cascade)
}

model SavedRecipe {
  id            String     @id @default(cuid())
  userId        String
  recipeId      String
  savedAt       DateTime   @default(now())

  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipe        Recipe     @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@unique([userId, recipeId])
}

model RecipeRating {
  id            String     @id @default(cuid())
  userId        String
  recipeId      String
  rating        Int
  ratedAt       DateTime   @default(now())

  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipe        Recipe     @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@unique([userId, recipeId])
}

model MealPlan {
  id            String     @id @default(cuid())
  userId        String
  weekStart     DateTime
  name          String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  meals         MealPlanRecipe[]
}

model MealPlanRecipe {
  id            String     @id @default(cuid())
  mealPlanId    String
  recipeId      String
  day           String
  mealType      String

  mealPlan      MealPlan   @relation(fields: [mealPlanId], references: [id], onDelete: Cascade)
  recipe        Recipe     @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@unique([mealPlanId, day, mealType])
}

model GroceryList {
  id            String     @id @default(cuid())
  userId        String
  name          String
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items         GroceryItem[]
}

model GroceryItem {
  id            String     @id @default(cuid())
  groceryListId String
  ingredientId  String?
  recipeId      String?
  name          String
  quantity      Float
  unit          String
  category      String
  checked       Boolean    @default(false)
  createdAt     DateTime   @default(now())

  groceryList   GroceryList @relation(fields: [groceryListId], references: [id], onDelete: Cascade)
  ingredient    Ingredient? @relation(fields: [ingredientId], references: [id], onDelete: SetNull)
  recipe        Recipe?    @relation(fields: [recipeId], references: [id], onDelete: SetNull)
}

model Cookbook {
  id            String     @id @default(cuid())
  userId        String
  name          String
  description   String?
  coverImage    String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipes       CookbookRecipe[]
}

model CookbookRecipe {
  id            String     @id @default(cuid())
  cookbookId    String
  recipeId      String

  cookbook      Cookbook   @relation(fields: [cookbookId], references: [id], onDelete: Cascade)
  recipe        Recipe     @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@unique([cookbookId, recipeId])
}

// A family/household that shares a live grocery list. Members join with the
// invite code. Everyone in the household reads and writes the same items, so a
// change on one phone shows up on the others (the client polls while open).
model Household {
  id           String    @id @default(cuid())
  name         String
  // Short, human-typable code (e.g. "K4P7QR"). Unique so joins are unambiguous.
  inviteCode   String    @unique
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  members      HouseholdMember[]
  groceryItems SharedGroceryItem[]
}

model HouseholdMember {
  id          String    @id @default(cuid())
  householdId String
  userId      String
  // "owner" (the creator) or "member".
  role        String    @default("member")
  joinedAt    DateTime  @default(now())

  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  // A user is in at most one household, enforced in the join/create routes; this
  // just stops the same user being added twice to the same one.
  @@unique([householdId, userId])
  @@index([userId])
}

model SharedGroceryItem {
  id          String    @id @default(cuid())
  householdId String
  name        String
  quantity    Float     @default(1)
  unit        String    @default("piece")
  category    String    @default("general")
  checked     Boolean   @default(false)
  // Who added it, denormalized so the UI can show "added by Alex" without a join
  // and it survives that member leaving.
  addedById   String?
  addedByName String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  addedBy     User?     @relation("SharedGroceryAddedBy", fields: [addedById], references: [id], onDelete: SetNull)

  @@index([householdId])
}
