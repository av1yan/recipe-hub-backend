# Copy to .env for local development.
#
# The Prisma schema is postgres-only, so a SQLite "file:./dev.db" URL will not
# work here. `npm run db:local` starts a real Postgres from node_modules (no
# system install, no Docker) on port 5433 and prints this exact URL:
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/recipihub"

JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"

# The frontend's VITE_API_URL must point at this port to use a local backend.
PORT=5001

NODE_ENV=development
