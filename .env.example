# Copy to .env for local development.
#
# The Prisma schema is postgres-only, so a SQLite "file:./dev.db" URL will not
# work here. `npm run db:local` starts a real Postgres from node_modules (no
# system install, no Docker) on port 5433 and prints this exact URL:
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/recipihub"

JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"

# The frontend's VITE_API_URL must point at this port to use a local backend.
PORT=5001

NODE_ENV=development

# ─── OAuth (optional) ────────────────────────────────────────────────────────
# Unset, /api/auth/oauth/providers reports false and the app hides the
# Google/Apple buttons. See docs/oauth-setup.md for how to fill these in.
PUBLIC_API_URL="http://localhost:5001"
FRONTEND_URL="http://localhost:5174"
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""
# APPLE_SERVICES_ID=""
# APPLE_TEAM_ID=""
# APPLE_KEY_ID=""
# APPLE_PRIVATE_KEY=""

# ─── Password reset email (optional) ─────────────────────────────────────────
# Unset, /api/auth/password-reset/available reports false and the app hides the
# "Forgot password?" link. See docs/email-setup.md.
# RESEND_API_KEY=""
# RESEND_FROM="recipHub <no-reply@yourdomain.com>"   # defaults to Resend's shared sender
